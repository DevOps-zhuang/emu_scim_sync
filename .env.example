# General
LOG_LEVEL=INFO
LOG_FORMAT=text
LOG_FILE=logs/emu_scim_sync.log
LOG_FILE_MAX_BYTES=1048576
LOG_FILE_BACKUP_COUNT=5
SYNC_INTERVAL_MINUTES=15
DRY_RUN=true
HARD_DELETE_REMOVED_USERS=false
GROUP_DELETE_GRACE_RUNS=2
GROUP_DELETE_MAX_PERCENT=20
STATE_STORE_BACKEND=local_json

# Entra ID (21V China)
ENTRA_TENANT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
ENTRA_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
ENTRA_CLIENT_SECRET=your-secret
ENTRA_TOKEN_URL=https://login.partner.microsoftonline.cn/{tenant_id}/oauth2/v2.0/token
GRAPH_BASE_URL=https://microsoftgraph.chinacloudapi.cn/v1.0

# Scope sync to multiple Entra security groups by displayName
ENTRA_SYNC_GROUP_NAMES=GitHub-EMU-Platform,GitHub-EMU-SRE

# GitHub EMU SCIM
GITHUB_ENTERPRISE=your-enterprise-slug
GITHUB_SCIM_BASE_URL=https://api.github.com/scim/v2/enterprises/{enterprise}
GITHUB_PAT=ghp_xxx
GITHUB_USER_AGENT=emu-scim-sync/0.1
# Optional: comma-separated Entra userPrincipalName values to sync as enterprise administrators
GITHUB_ENTERPRISE_ADMIN_UPNS=

# Local state
STATE_FILE=state/sync_state.json

# When LOG_FILE is configured, each run writes a timestamped file like
# logs/emu_scim_sync_20260322_090015_apply.log or ..._dryrun.log
